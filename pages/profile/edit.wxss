.container { min-height: 100vh; background: #FFF8F5; }
.avatar-section { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0 30rpx; }
.edit-avatar { width: 160rpx; height: 160rpx; border-radius: 50%; border: 4rpx solid #FFE0D0; }
.avatar-tip { font-size: 24rpx; color: #FF8C69; margin-top: 12rpx; }
.radio-group { display: flex; gap: 16rpx; justify-content: flex-end; }
.radio-item { padding: 8rpx 24rpx; border-radius: 30rpx; border: 2rpx solid #ddd; font-size: 26rpx; color: #666; }
.radio-item.active { border-color: #FF8C69; color: #FF8C69; background: #FFF0EB; }
