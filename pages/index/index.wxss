.container { min-height: 100vh; background: #FFF8F5; }

.header {
  background: linear-gradient(135deg, #FF8C69, #FFB347);
  padding: 40rpx 30rpx 20rpx;
}
.header-label { font-size: 30rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 20rpx; }

.cat-tabs { white-space: nowrap; }
.cat-tab-list { display: inline-flex; padding-bottom: 10rpx; }
.cat-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.2);
  min-width: 80rpx;
}
.cat-tab.active { background: rgba(255,255,255,0.9); }
.cat-avatar-sm { width: 60rpx; height: 60rpx; border-radius: 50%; }
.cat-tab-name { font-size: 22rpx; color: #fff; margin-top: 6rpx; }
.cat-tab.active .cat-tab-name { color: #FF8C69; }
.add-tab { background: rgba(255,255,255,0.15); }
.add-icon { font-size: 36rpx; color: #fff; line-height: 60rpx; }

.empty-home {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx;
}
.empty-cat-img { width: 200rpx; height: 200rpx; opacity: 0.4; }
.empty-title { font-size: 36rpx; font-weight: bold; color: #666; margin-top: 30rpx; }
.empty-desc { font-size: 28rpx; color: #999; margin-top: 12rpx; }
.add-cat-btn { margin-top: 50rpx; width: 400rpx; }

.cat-info-card { cursor: pointer; }
.cat-info-row { display: flex; align-items: center; }
.cat-avatar-lg { width: 120rpx; height: 120rpx; border-radius: 50%; border: 4rpx solid #FFE0D0; flex-shrink: 0; }
.cat-info-detail { flex: 1; margin-left: 24rpx; }
.cat-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx; }
.cat-name { font-size: 36rpx; font-weight: bold; color: #333; }
.cat-meta { font-size: 24rpx; color: #999; display: flex; align-items: center; margin-bottom: 10rpx; }
.meta-sep { margin: 0 8rpx; }
.cat-weight { display: flex; align-items: center; gap: 12rpx; }
.weight-val { font-size: 28rpx; font-weight: bold; color: #FF8C69; }

.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; }
.card-more { font-size: 24rpx; color: #FF8C69; }

.reminder-empty { font-size: 26rpx; color: #ccc; text-align: center; padding: 20rpx 0; }
.reminder-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.reminder-item.urgent { background: #FFF8F5; border-radius: 12rpx; padding: 16rpx; margin-bottom: 8rpx; border-bottom: none; }
.reminder-type { font-size: 28rpx; color: #333; font-weight: 500; }
.reminder-date { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.reminder-days { font-size: 26rpx; font-weight: bold; }
.reminder-days.overdue { color: #FF3B30; }
.reminder-days.soon { color: #FF9500; }
.reminder-days.normal { color: #34C759; }

.weight-overview { display: flex; flex-direction: column; }
.weight-main { display: flex; align-items: baseline; }
.weight-big { font-size: 64rpx; font-weight: bold; color: #FF8C69; }
.weight-unit { font-size: 28rpx; color: #999; margin-left: 8rpx; }
.weight-info { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.weight-date { font-size: 24rpx; color: #999; }
.food-suggest { display: flex; align-items: center; margin-top: 16rpx; font-size: 26rpx; color: #666; background: #FFF8F5; padding: 12rpx 16rpx; border-radius: 12rpx; }
.food-icon { margin-right: 8rpx; }
