<view class="container">
  <!-- 月份切换 -->
  <view class="month-nav">
    <view class="nav-btn" bindtap="prevMonth">‹</view>
    <text class="month-title">{{year}}年{{month}}月</text>
    <view class="nav-btn" bindtap="nextMonth">›</view>
  </view>

  <!-- 星期头 -->
  <view class="week-header">
    <text wx:for="{{weekDays}}" wx:key="*this" class="week-day">{{item}}</text>
  </view>

  <!-- 日历格子 -->
  <view class="calendar-grid">
    <view
      wx:for="{{calendarDays}}"
      wx:key="index"
      class="day-cell {{item.isToday ? 'today' : ''}} {{item.empty ? 'empty' : ''}}"
    >
      <text class="day-num">{{item.day}}</text>
      <view wx:if="{{item.internal}}" class="dot dot-internal"></view>
      <view wx:if="{{item.external}}" class="dot dot-external"></view>
    </view>
  </view>

  <!-- 图例 -->
  <view class="legend card">
    <view class="legend-item"><view class="dot dot-internal"></view><text>体内驱虫</text></view>
    <view class="legend-item"><view class="dot dot-external"></view><text>体外驱虫</text></view>
  </view>

  <!-- 当月记录列表 -->
  <view class="card" wx:if="{{monthRecords.length > 0}}">
    <text class="section-title">本月驱虫记录</text>
    <view wx:for="{{monthRecords}}" wx:key="id" class="record-row">
      <view class="record-dot {{item.type === 'internal' ? 'dot-internal' : 'dot-external'}}"></view>
      <text class="record-date">{{item.date}}</text>
      <text class="record-type">{{item.type === 'internal' ? '体内' : '体外'}}</text>
      <text class="record-med">{{item.medicine}}</text>
    </view>
  </view>
  <view class="safe-bottom"></view>
</view>
