.container { min-height: 100vh; background: #FFFBF5; }
.month-nav { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 40rpx; background: #fff; }
.nav-btn { font-size: 48rpx; color: #FF6B9D; padding: 0 20rpx; }
.month-title { font-size: 32rpx; font-weight: bold; color: #333; }
.week-header { display: flex; background: #fff; padding: 0 16rpx 12rpx; }
.week-day { flex: 1; text-align: center; font-size: 22rpx; color: #999; }
.calendar-grid { display: flex; flex-wrap: wrap; background: #fff; padding: 0 16rpx 16rpx; margin-bottom: 4rpx; }
.day-cell { width: 14.28%; display: flex; flex-direction: column; align-items: center; padding: 10rpx 0; min-height: 80rpx; }
.day-cell.empty { }
.day-num { font-size: 26rpx; color: #333; }
.day-cell.today .day-num { color: #fff; background: #FF6B9D; border-radius: 50%; width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center; }
.dot { width: 10rpx; height: 10rpx; border-radius: 50%; margin: 2rpx; }
.dot-internal { background: #A78BFA; }
.dot-external { background: #00C9A7; }
.legend { display: flex; gap: 40rpx; }
.legend-item { display: flex; align-items: center; gap: 10rpx; font-size: 24rpx; color: #666; }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }
.record-row { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.record-date { font-size: 26rpx; color: #666; flex: 1; }
.record-type { font-size: 24rpx; color: #999; }
.record-med { font-size: 24rpx; color: #999; }
