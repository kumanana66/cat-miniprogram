.container { min-height: 100vh; background: #FFFBF5; }
.tab-bar { display: flex; background: #fff; border-bottom: 1rpx solid #F5F5F5; }
.tab-item { flex: 1; text-align: center; padding: 28rpx 0; font-size: 28rpx; color: #999; }
.tab-item.active { color: #FF6B9D; border-bottom: 4rpx solid #FF6B9D; font-weight: bold; }
.reminder-card { padding: 24rpx 30rpx; }
.reminder-card.done { opacity: 0.6; }
.reminder-main { display: flex; justify-content: space-between; align-items: center; }
.reminder-info { flex: 1; }
.reminder-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.reminder-title.done-title { text-decoration: line-through; color: #999; }
.reminder-date { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }
.reminder-actions { flex-shrink: 0; }
.reminder-btns { display: flex; gap: 16rpx; margin-top: 16rpx; }
.btn-done { flex: 1; font-size: 24rpx; padding: 10rpx 0; border-radius: 30rpx; background: #E6FAF6; color: #00C9A7; border: none; }
.btn-done::after { border: none; }
.btn-del-sm { flex: 1; font-size: 24rpx; padding: 10rpx 0; border-radius: 30rpx; background: #FFEBEA; color: #FF3B30; border: none; }
.btn-del-sm::after { border: none; }
.add-fab {
  position: fixed; right: 40rpx; bottom: 160rpx;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D, #FF8E53);
  color: #fff; font-size: 56rpx; line-height: 100rpx; text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255,107,157,0.4);
}
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; z-index: 100; }
.modal-box { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 30rpx; width: 100%; }
.modal-title { font-size: 32rpx; font-weight: bold; color: #333; display: block; margin-bottom: 20rpx; }
