.container { min-height: 100vh; background: #FFFBF5; }
.upload-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 30rpx; background: #fff; }
.upload-btn { font-size: 26rpx; color: #FF6B9D; background: #FFF0F5; border: none; border-radius: 30rpx; padding: 12rpx 30rpx; }
.upload-btn::after { border: none; }
.photo-count { font-size: 24rpx; color: #999; }
.date-label { font-size: 24rpx; color: #999; padding: 16rpx 30rpx 8rpx; }
.photo-grid { display: flex; flex-wrap: wrap; padding: 0 4rpx; }
.photo-item { width: 33.33%; padding: 4rpx; position: relative; box-sizing: border-box; }
.photo-img { width: 100%; height: 230rpx; display: block; border-radius: 8rpx; }
.photo-item.selected .photo-img { opacity: 0.7; }
.select-check { position: absolute; top: 12rpx; right: 12rpx; width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid #fff; background: rgba(0,0,0,0.3); color: #fff; font-size: 24rpx; line-height: 40rpx; text-align: center; }
.select-check.checked { background: #FF6B9D; border-color: #FF6B9D; }
.select-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #F5F5F5; display: flex; align-items: center; padding: 16rpx 20rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); gap: 12rpx; }
.sel-btn { flex: 1; font-size: 24rpx; padding: 14rpx 0; border-radius: 30rpx; border: none; }
.sel-btn::after { border: none; }
.sel-cancel { background: #F5F5F5; color: #666; }
.sel-save { background: #E6FAF6; color: #00C9A7; }
.sel-del { background: #FFEBEA; color: #FF3B30; }
.sel-count { font-size: 24rpx; color: #999; white-space: nowrap; }
