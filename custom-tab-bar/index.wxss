.tab-bar {
  display: flex;
  height: 112rpx;
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 12rpx;
}

.tab-dot {
  width: 48rpx;
  height: 8rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  transition: all 0.2s;
}

.tab-text {
  font-size: 22rpx;
  font-weight: 500;
  transition: color 0.2s;
}

.tab-item.active .tab-text {
  font-weight: 700;
}
